# Monitor ANM - Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env a GitHub

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=tu-anon-key-aqui

# JWT (cambia por una cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-algo-muy-largo-y-aleatorio-abc123xyz!

# WhatsApp - CallMeBot (gratis)
# Instrucciones: Envía "I allow callmebot to send me messages"
# al número +34 644 59 72 97 por WhatsApp y recibirás tu API Key
CALLMEBOT_KEY=tu-api-key-de-callmebot

# Entorno: dev o production
ENV=dev
